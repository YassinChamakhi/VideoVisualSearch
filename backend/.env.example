# Video Visual Search — Backend Environment Variables
# Copy this file to .env and fill in any custom values.

# Host/port for the backend server
HOST=0.0.0.0
PORT=8000

# CLIP model to use (change to a larger model for better accuracy)
# Options: openai/clip-vit-base-patch32  (default, fast)
#          openai/clip-vit-large-patch14 (slower, more accurate)
CLIP_MODEL=openai/clip-vit-base-patch32

# Max video size in MB (default 500)
MAX_VIDEO_SIZE_MB=500

# Default FPS for frame extraction (overridable per request)
DEFAULT_FPS=1.0

# Logging level
LOG_LEVEL=INFO
